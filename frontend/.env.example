# ======================================================
# GT-Vision Frontend - Environment Variables
# ======================================================

# Backend API (Django - porta 8000)
VITE_API_URL=http://localhost:8000/api

# Streaming API (FastAPI - porta 8001)
VITE_STREAMING_URL=http://localhost:8001/api

# Detection API (FastAPI - porta 8002)
VITE_DETECTION_URL=http://localhost:8002/api

# MediaMTX HLS (porta 8889)
VITE_HLS_URL=http://localhost:8889

# WebSocket URL
VITE_WS_URL=ws://localhost:8001/ws
